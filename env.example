# Copy thành .env.local (không commit file .env.local)

# --- Local dev ---
NEXT_PUBLIC_SITE_URL=http://localhost:5173

# --- Supabase (Dashboard → Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=paste-anon-public-key-here

# --- Admin (/admin) — chỉ dùng ADMIN_EMAIL trên server ---
ADMIN_EMAIL=admin@juzlegal.vn
# NEXT_PUBLIC_ADMIN_EMAIL chỉ cần nếu legacy client; ưu tiên ADMIN_EMAIL
# NEXT_PUBLIC_ADMIN_EMAIL=admin@juzlegal.vn

# Mật khẩu admin — chỉ dùng khi chạy npm run supabase:admin (không commit)
# ADMIN_PASSWORD=your-strong-password

# Mật khẩu database — chỉ dùng script SQL local (Dashboard → Settings → Database)
# SUPABASE_DB_PASSWORD=your-db-password

# --- Service role (server-only) — ghi dữ liệu VBPL sync vào Supabase ---
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI trích xuất văn bản từ vbpl.vn ---
# AI_API_KEY=sk-...
# AI_API_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...  # alias của AI_API_KEY

# --- Cron đồng bộ vbpl (Vercel Cron / external scheduler) ---
# VBPL_SYNC_SECRET=random-long-secret

# --- Legal library / VBPL AI sync ---
# npm run supabase:legal-schema
# npm run vbpl:seed-queue
# Admin UI: /admin/thu-vien-phap-luat

# --- Email thông báo đặt lịch / liên hệ (Resend) ---
BOOKING_NOTIFY_EMAIL=juz.legal@gmail.com
RESEND_API_KEY=re_xxxxxxxx
# Sau khi verify domain trên Resend:
EMAIL_FROM=JUZ Legal <notifications@juzlegal.com>

# --- Zalo ZNS (tùy chọn — xác nhận lịch qua Zalo OA) ---
# ZALO_OA_ID=
# ZALO_APP_ID=
# ZALO_APP_SECRET=
# ZALO_REFRESH_TOKEN=
# ZALO_TEMPLATE_ID_BOOKING_CONFIRMED=

# --- Rate limit bền vững (tùy chọn — Upstash Redis) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Analytics ---
NEXT_PUBLIC_GA_ID=G-NX6GE58D37

# --- Vercel sync ---
# Production/Preview: npm run vercel:sync-preview
# Full sync từ .env.local: npm run vercel:sync-env
